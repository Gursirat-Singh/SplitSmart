generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ENUMS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

/// Supported currencies for expenses and settlements.
enum Currency {
  INR
  USD
}

/// How an expense is divided among participants.
///   EQUAL      – total ÷ active members
///   EXACT      – caller specifies each member's absolute share
///   PERCENTAGE – caller specifies each member's % share
enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
}

/// Classification of issues found during CSV import parsing.
enum AnomalyType {
  INVALID_AMOUNT
  MISSING_FIELD
  UNKNOWN_MEMBER
  INACTIVE_MEMBER
  INVALID_DATE
  INVALID_SPLIT
  DUPLICATE_ENTRY
  CURRENCY_MISMATCH
  OTHER
}

/// Whether an import anomaly caused the row to be skipped or partially imported.
enum AnomalySeverity {
  WARNING // Row was imported with adjustments
  ERROR // Row was skipped entirely
}

/// Verdict for a single row in an import batch.
enum ImportRowVerdict {
  IMPORTED
  SKIPPED
  FLAGGED
  ACCEPTED
  REJECTED
}

/// Status of a CSV import batch.
enum ImportStatus {
  PROCESSING
  COMPLETED
  FAILED
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// MODELS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

/// ──────────────────────────────────────────────────────────
/// USER
/// ──────────────────────────────────────────────────────────
/// Central identity for authentication and all ownership references.
///
/// WHY IT EXISTS:
/// Every action in the system (creating a group, paying an expense,
/// recording a settlement, importing a CSV) must be attributable to
/// an authenticated user. This table stores JWT-compatible credentials
/// and serves as the FK target for all "who did this?" columns.
/// ──────────────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  name         String   @db.VarChar(100)
  createdAt    DateTime @default(now()) @db.Timestamptz()
  updatedAt    DateTime @updatedAt @db.Timestamptz()

  // ── Outgoing relations ───────────────────────────────────
  memberships         GroupMembership[]
  createdGroups       Group[]           @relation("GroupCreator")
  paidExpenses        Expense[]         @relation("ExpensePayer")
  expenseShares       ExpenseShare[]
  settlementsPaid     Settlement[]      @relation("SettlementPayer")
  settlementsReceived Settlement[]      @relation("SettlementPayee")
  imports             Import[]

  @@map("users")
}

/// ──────────────────────────────────────────────────────────
/// GROUP
/// ──────────────────────────────────────────────────────────
/// A named container that scopes expenses, memberships, and
/// settlements together.
///
/// WHY IT EXISTS:
/// Splitwise-style apps organize financial activity into groups
/// (e.g. "Goa Trip", "Flatmates"). Every expense, settlement,
/// and membership interval is scoped to exactly one group.
/// The creator is tracked for ownership and admin privileges.
/// ──────────────────────────────────────────────────────────
model Group {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(150)
  description String?  @db.Text
  createdById String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz()
  updatedAt   DateTime @updatedAt @db.Timestamptz()

  // ── Relations ────────────────────────────────────────────
  /// Restrict: cannot delete a user who still owns groups.
  createdBy   User              @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Restrict)
  memberships GroupMembership[]
  expenses    Expense[]
  settlements Settlement[]
  imports     Import[]

  @@index([createdById])
  @@map("groups")
}

/// ──────────────────────────────────────────────────────────
/// GROUP MEMBERSHIP
/// ──────────────────────────────────────────────────────────
/// A temporal interval recording when a user was an active
/// member of a group.  joinedAt marks the start; leftAt marks
/// the end (NULL = currently active).
///
/// WHY IT EXISTS:
/// Members can join and leave groups over time. A user who
/// leaves and re-joins gets a NEW row, creating a complete
/// audit history. When recording an expense, the system queries
/// this table to determine who was active on the expense date:
///
///   WHERE joinedAt <= expenseDate
///     AND (leftAt IS NULL OR leftAt > expenseDate)
///
/// This ensures expenses only affect members who were present.
/// ──────────────────────────────────────────────────────────
model GroupMembership {
  id       String    @id @default(uuid()) @db.Uuid
  userId   String    @db.Uuid
  groupId  String    @db.Uuid
  joinedAt DateTime  @default(now()) @db.Timestamptz()
  leftAt   DateTime? @db.Timestamptz()

  // ── Relations ────────────────────────────────────────────
  /// Cascade: if a user is deleted, their membership history goes too.
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Cascade: if a group is deleted, all membership rows for it are removed.
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // ── Indexes ──────────────────────────────────────────────
  /// Fast lookup: "all memberships for user X in group Y"
  @@index([groupId, userId])
  /// Range scan: "who was active in group Y on date Z?"
  @@index([groupId, joinedAt, leftAt])
  /// Lookup: "all groups user X belongs to"
  @@index([userId])
  @@map("group_memberships")
}

/// ──────────────────────────────────────────────────────────
/// EXPENSE
/// ──────────────────────────────────────────────────────────
/// A single expense event: "User X paid ₹1200 for dinner on
/// 2024-03-15 in Group Y, split equally."
///
/// WHY IT EXISTS:
/// This is the core financial record. It captures WHO paid,
/// HOW MUCH, in WHAT CURRENCY, WHEN it happened, and HOW
/// it should be divided. The actual per-person obligations
/// are stored in ExpenseShare (child rows).
///
/// Settlements are intentionally stored in a separate table
/// to avoid polluting expense queries and balance aggregations.
/// ──────────────────────────────────────────────────────────
model Expense {
  id          String    @id @default(uuid()) @db.Uuid
  groupId     String    @db.Uuid
  paidById    String    @db.Uuid
  amount      Decimal   @db.Decimal(12, 2)
  currency    Currency  @default(INR)
  description String    @db.VarChar(300)
  splitType   SplitType
  expenseDate DateTime  @db.Timestamptz()
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @db.Timestamptz()

  // ── Relations ────────────────────────────────────────────
  /// Cascade: deleting a group removes all its expenses.
  group      Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  /// Restrict: cannot delete a user who has paid expenses (preserve financial history).
  paidBy     User           @relation("ExpensePayer", fields: [paidById], references: [id], onDelete: Restrict)
  shares     ExpenseShare[]
  importRows ImportRow[]

  // ── Indexes ──────────────────────────────────────────────
  /// Balance calc: fetch all expenses in a group, optionally filtered by date range.
  @@index([groupId, expenseDate])
  /// Balance calc: "all expenses paid by user X" for the payer-side aggregation.
  @@index([groupId, paidById])
  /// Dashboard: "my recent expenses across all groups"
  @@index([paidById])
  @@map("expenses")
}

/// ──────────────────────────────────────────────────────────
/// EXPENSE SHARE
/// ──────────────────────────────────────────────────────────
/// The individual obligation a participant owes for a single
/// expense. One row per participant per expense.
///
/// WHY IT EXISTS:
/// An expense of ₹1200 split among 4 people produces 4 share
/// rows of ₹300 each. Storing pre-computed absolute amounts
/// (even for percentage splits) avoids rounding drift on reads
/// and makes balance queries a simple SUM().
///
/// Balance formula uses this table:
///   owes(A→B) = SUM(shares where A is userId AND expense.paidBy = B)
///             – SUM(shares where B is userId AND expense.paidBy = A)
/// ──────────────────────────────────────────────────────────
model ExpenseShare {
  id        String  @id @default(uuid()) @db.Uuid
  expenseId String  @db.Uuid
  userId    String  @db.Uuid
  amount    Decimal @db.Decimal(12, 2)

  // ── Relations ────────────────────────────────────────────
  /// Cascade: deleting an expense removes all its shares.
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  /// Restrict: cannot delete a user who has expense share records.
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  // ── Indexes ──────────────────────────────────────────────
  /// Uniqueness: a user appears at most once per expense.
  @@unique([expenseId, userId])
  /// Balance calc: "total owed by user X across all expenses" (joined with Expense for groupId filter).
  @@index([userId])
  /// Balance calc: covering index for fetching all shares of an expense.
  @@index([expenseId])
  @@map("expense_shares")
}

/// ──────────────────────────────────────────────────────────
/// SETTLEMENT
/// ──────────────────────────────────────────────────────────
/// A direct payment from one member to another to reduce debt.
/// e.g. "Alice paid Bob ₹500 to settle up."
///
/// WHY IT EXISTS:
/// Settlements are NOT expenses — they don't generate shares or
/// affect who owes what for a specific purchase. They only reduce
/// the net balance between two people. Keeping them separate
/// ensures:
///   1. Expense queries aren't polluted with settlement records
///   2. Balance formula is clean:
///      net(A→B) = expense_debt(A→B) – settlements(A→B) + settlements(B→A)
///   3. Settlement history is independently auditable
/// ──────────────────────────────────────────────────────────
model Settlement {
  id        String   @id @default(uuid()) @db.Uuid
  groupId   String   @db.Uuid
  paidById  String   @db.Uuid
  paidToId  String   @db.Uuid
  amount    Decimal  @db.Decimal(12, 2)
  currency  Currency @default(INR)
  settledAt DateTime @default(now()) @db.Timestamptz()
  createdAt DateTime @default(now()) @db.Timestamptz()

  // ── Relations ────────────────────────────────────────────
  /// Cascade: deleting a group removes all its settlements.
  group  Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  /// Restrict: cannot delete a user involved in settlements.
  paidBy User  @relation("SettlementPayer", fields: [paidById], references: [id], onDelete: Restrict)
  paidTo User  @relation("SettlementPayee", fields: [paidToId], references: [id], onDelete: Restrict)

  // ── Indexes ──────────────────────────────────────────────
  /// Balance calc: all settlements in a group (primary query path).
  @@index([groupId])
  /// Balance calc: "settlements where A paid" within a group.
  @@index([groupId, paidById])
  /// Balance calc: "settlements where A received" within a group.
  @@index([groupId, paidToId])
  @@map("settlements")
}

/// ──────────────────────────────────────────────────────────
/// IMPORT
/// ──────────────────────────────────────────────────────────
/// Tracks a single CSV import operation as a batch. Records who
/// triggered it, which group it targets, and aggregate results.
///
/// WHY IT EXISTS:
/// CSV imports can create dozens of expenses at once. This table
/// provides:
///   1. Batch identity: group all imported expenses under one run
///   2. Progress tracking: totalRows vs successCount vs failureCount
///   3. Audit trail: who imported what, when
///   4. Parent for ImportAnomaly rows (every issue is traceable
///      back to a specific import run)
/// ──────────────────────────────────────────────────────────
model Import {
  id           String       @id @default(uuid()) @db.Uuid
  groupId      String       @db.Uuid
  importedById String       @db.Uuid
  fileName     String       @db.VarChar(255)
  totalRows    Int
  successCount Int          @default(0)
  failureCount Int          @default(0)
  status       ImportStatus @default(PROCESSING)
  createdAt    DateTime     @default(now()) @db.Timestamptz()
  completedAt  DateTime?    @db.Timestamptz()

  // ── Relations ────────────────────────────────────────────
  /// Cascade: deleting a group removes its import history.
  group      Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  /// Restrict: cannot delete a user who initiated imports.
  importedBy User            @relation(fields: [importedById], references: [id], onDelete: Restrict)
  anomalies  ImportAnomaly[]
  rows       ImportRow[]

  // ── Indexes ──────────────────────────────────────────────
  @@index([groupId])
  @@index([importedById])
  @@map("imports")
}

/// ──────────────────────────────────────────────────────────
/// IMPORT ANOMALY
/// ──────────────────────────────────────────────────────────
/// A single issue detected on a single CSV row during import.
/// One row in this table = one anomaly.
///
/// WHY IT EXISTS:
/// The requirement states "every anomaly detected during import
/// must be logged and traceable." This table satisfies that by
/// recording:
///   - WHICH import batch (importId → Import)
///   - WHICH row in the CSV (rowNumber)
///   - WHAT went wrong (type enum + human-readable message)
///   - HOW severe (WARNING = partially imported, ERROR = skipped)
///   - THE RAW DATA (rawData JSONB preserves the original CSV
///     row for post-mortem debugging without re-uploading)
/// ──────────────────────────────────────────────────────────
model ImportAnomaly {
  id        String          @id @default(uuid()) @db.Uuid
  importId  String          @db.Uuid
  rowNumber Int
  type      AnomalyType
  severity  AnomalySeverity
  field     String?         @db.VarChar(50)
  message   String          @db.Text
  rawData   Json?           @db.JsonB
  createdAt DateTime        @default(now()) @db.Timestamptz()

  // ── Relations ────────────────────────────────────────────
  /// Cascade: deleting an import run removes all its anomaly logs.
  import Import @relation(fields: [importId], references: [id], onDelete: Cascade)

  // ── Indexes ──────────────────────────────────────────────
  /// Primary lookup: all anomalies for a given import.
  @@index([importId])
  /// Filtered lookup: anomalies of a specific type within an import.
  @@index([importId, type])
  /// Filtered lookup: only errors (or only warnings) within an import.
  @@index([importId, severity])
  @@map("import_anomalies")
}

/// ──────────────────────────────────────────────────────────
/// IMPORT ROW
/// ──────────────────────────────────────────────────────────
/// Records the verdict and data for every row processed during
/// a CSV import.
///
/// WHY IT EXISTS:
/// Required for full auditability of the import process. This
/// ensures no row is ever silently dropped. It links to the
/// created expense (if imported) or records the user review
/// decision (if flagged).
/// ──────────────────────────────────────────────────────────
model ImportRow {
  id         String           @id @default(uuid()) @db.Uuid
  importId   String           @db.Uuid
  rowNumber  Int
  verdict    ImportRowVerdict
  rawData    Json             @db.JsonB
  expenseId  String?          @db.Uuid
  reviewedAt DateTime?        @db.Timestamptz()
  reviewNote String?          @db.Text

  // ── Relations ────────────────────────────────────────────
  import  Import   @relation(fields: [importId], references: [id], onDelete: Cascade)
  expense Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  @@unique([importId, rowNumber])
  @@index([importId, verdict])
  @@map("import_rows")
}
